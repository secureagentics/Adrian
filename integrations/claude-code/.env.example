# Adrian CC Plugin Configuration
# Copy this to .env in your project root (the directory you run Claude Code from).

# Adrian API key (get from Adrian dashboard → Agents → New Key)
ADRIAN_API_KEY=adr_live_your_key_here

# Adrian backend WebSocket URL
ADRIAN_WS_URL=ws://localhost:8080/ws

# Verdict timeout in seconds (fail-open after this)
ADRIAN_CC_VERDICT_TIMEOUT=15

# Fail-open policy: true = allow on timeout/error, false = block
ADRIAN_CC_FAIL_OPEN=true
